<?xml version="1.0" encoding="utf-8"?>
<!--
  Production posture: cleartext HTTP is disabled by default (base-config), so
  release builds only ever talk HTTPS. Cleartext is permitted only for the
  local development backend hosts, so `flutter run` against a plain-HTTP Spring
  Boot server on your machine still works.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>       <!-- Android emulator -> host -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
