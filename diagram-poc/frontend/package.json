{
  "name": "diagram-builder-frontend",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "concurrently -n app,collab -c cyan,green \"ng serve\" \"node collab-server.mjs\"",
    "serve": "ng serve",
    "collab-server": "node collab-server.mjs",
    "start:all": "concurrently -n app,collab -c cyan,green \"ng serve\" \"node collab-server.mjs\"",
    "start:lan": "concurrently -n app,collab -c cyan,green \"ng serve --host 0.0.0.0\" \"HOST=0.0.0.0 node collab-server.mjs\"",
    "build": "ng build",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadlessCI"
  },
  "private": true,
