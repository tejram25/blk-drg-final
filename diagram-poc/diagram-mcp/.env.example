# Where the Spring BFF is reachable (no trailing slash).
DIAGRAM_BFF_URL=http://localhost:8080

# Credentials the agent authenticates with. The BFF uses password + session-cookie
# auth (POST /api/auth/login), so the server logs in once and reuses the session.
DIAGRAM_BFF_EMAIL=agent@example.com
DIAGRAM_BFF_PASSWORD=change-me

# The collaboration relay (y-websocket) the live bot joins. Room is gojs-<diagramId>.
DIAGRAM_COLLAB_WS_URL=ws://localhost:1234

# Display name/uid the bot shows as in a session's presence roster.
DIAGRAM_BOT_NAME=Claude
DIAGRAM_BOT_UID=ai-agent
