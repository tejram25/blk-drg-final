{
  "name": "diagram-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Model Context Protocol server exposing the Block Diagram app (read + write) plus a Yjs live-collaboration bot, so an AI agent can join a diagram session and edit the shared canvas.",
  "bin": {
    "diagram-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "bot:demo": "node dist/yjsBot.js --demo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "undici": "^6.19.8",
    "ws": "^8.18.0",
    "y-protocols": "^1.0.6",
    "y-websocket": "^2.0.4",
    "yjs": "^13.6.31",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/ws": "^8.5.12",
    "typescript": "^5.6.2"
  }
}
