{
  "info": {
    "name": "Arrow APIM Part Search",
    "description": "Tests the Arrow APIM Part Search flow:\n1. Get an OAuth2 client-credentials token (saved to {{part_token}}).\n2. Search parts with the Bearer token.\n\nImport one of the environment files (DEV or QUAL), fill in client_id / client_secret, then run request 1 followed by request 2.\n\nThe token and search calls live on different hosts, which is why auth_base_url and search_base_url are separate variables.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Get OAuth Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Save the access token for the search request.",
              "let token = null;",
              "try {",
              "  const json = pm.response.json();",
              "  token = json.access_token || json.accessToken || json.token || (json.data && json.data.access_token);",
              "} catch (e) {",
              "  console.log('Token response was not JSON:', pm.response.text());",
              "}",
              "if (token) {",
              "  pm.environment.set('part_token', token);",
              "  pm.collectionVariables.set('part_token', token);",
              "  console.log('Saved part_token (' + token.length + ' chars).');",
              "} else {",
              "  console.log('No token field found. Status ' + pm.response.code + ': ' + pm.response.text());",
              "}",
              "pm.test('HTTP 200 from auth host', () => pm.response.to.have.status(200));",
              "pm.test('access_token present', () => pm.expect(token, 'access_token').to.be.a('string'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Version", "value": "{{version}}" }
        ],
        "body": {
          "mode": "raw",
          "options": { "raw": { "language": "json" } },
          "raw": "{\n  \"grant_type\": \"client_credentials\",\n  \"client_id\": \"{{client_id}}\",\n  \"client_secret\": \"{{client_secret}}\"\n}"
        },
        "url": {
          "raw": "{{auth_base_url}}/auth/oauth2/token",
          "host": ["{{auth_base_url}}"],
          "path": ["auth", "oauth2", "token"]
        },
        "description": "OAuth2 client-credentials grant. On success the test script stores access_token in {{part_token}}.\n\nA 503 here usually means the auth service/route is down (not a credentials problem); 401/403 means the credentials were rejected."
      }
    },
    {
      "name": "2. Part Search",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{part_token}}" }
        ],
        "url": {
          "raw": "{{search_base_url}}{{search_path}}?srchtxt={{srchtxt}}&render=json&appid={{app_id}}",
          "host": ["{{search_base_url}}{{search_path}}"],
          "query": [
            { "key": "srchtxt", "value": "{{srchtxt}}" },
            { "key": "render", "value": "json" },
            { "key": "appid", "value": "{{app_id}}" }
          ]
        },
        "description": "Calls {{search_base_url}}{{search_path}}. Run request 1 first so {{part_token}} is populated.\n\nThe response is the partserviceresult JSON the app renders into part cards."
      }
    }
  ],
  "variable": [
    { "key": "auth_base_url", "value": "https://gc-api-dev-apimgwt.apps.usdenpos01.arrow.com" },
    { "key": "search_base_url", "value": "https://gc-apim-dev1.azure-api.net" },
    { "key": "search_path", "value": "/arrowapi/dw/partservice/search" },
    { "key": "app_id", "value": "gen" },
    { "key": "version", "value": "v1" },
    { "key": "srchtxt", "value": "BAV99" },
    { "key": "client_id", "value": "" },
    { "key": "client_secret", "value": "" },
    { "key": "part_token", "value": "" }
  ]
}
