{
  "_comment": "Maps design-goal keywords to electronic-component catalogue search terms (grounded in Arrow.com's product taxonomy). Edit freely — reloaded on app restart. A rule fires when any of its single-word 'triggers' matches a word in the goal: exact token match, or a stem prefix for triggers >= 5 chars (e.g. 'regulat' -> 'regulator'). All of the rule's 'terms' are then searched in the Arrow catalogue. The recommendation caps the total number of searches, so breadth here is safe.",
  "rules": [
    {
      "terms": ["motor driver", "brushless motor controller", "stepper motor driver"],
      "triggers": ["robot", "amr", "agv", "motor", "servo", "drive", "actuator", "bldc", "brushless", "stepper", "gimbal", "propulsion"]
    },
    {
      "terms": ["IMU sensor", "accelerometer", "gyroscope"],
      "triggers": ["robot", "drone", "uav", "imu", "gyro", "gyroscope", "accel", "accelerometer", "navigation", "balance", "motion", "tilt", "vibration"]
    },
    {
      "terms": ["microcontroller", "microprocessor"],
      "triggers": ["mcu", "microcontroller", "microprocessor", "processor", "firmware", "embedded", "cortex", "stm32", "esp32", "avr", "pic", "risc"]
    },
    {
      "terms": ["FPGA", "CPLD"],
      "triggers": ["fpga", "cpld", "programmable", "verilog", "vhdl", "gateware"]
    },
    {
