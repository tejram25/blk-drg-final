# Copy this file to "application-local.properties" (same folder) and put your
# real Arrow credentials here. application-local.properties is gitignored, so it
# will NOT be committed. These values override the ones in application.properties.

# Arrow APIM Part Search credentials (from your APIM app registration).
arrow.client-id=your-client-id-here
arrow.client-secret=your-client-secret-here
# Defaults target DEV. For QUAL, also set:
# arrow.auth-base-url=https://gc-apim-qual1.azure-api.net
# arrow.search-base-url=https://gc-apiext-qual-apimgwq.apps.usdenpos02.arrow.com
# Search path (override only if your environment differs):
# arrow.search-path=/arrowapi/dw/partservice/search

# AI recommendations (local Ollama). Leave disabled to use the rule-based fallback.
# Install Ollama (https://ollama.com), run `ollama pull llama3.2`, then:
# ollama.enabled=true
# ollama.model=llama3.2
