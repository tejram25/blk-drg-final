# Copy this file to "application-local.properties" (same folder) and put your
# real Arrow credentials here. application-local.properties is gitignored, so it
# will NOT be committed. These values override the ones in application.properties.

arrow.client-id=your-client-id-here
arrow.client-secret=your-client-secret-here

# AI recommendations (Google Gemini). Leave unset to use the rule-based fallback.
# Free key (no card): https://aistudio.google.com/app/apikey
# gemini.api-key=AIza...
